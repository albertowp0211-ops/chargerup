# Variables de entorno del servidor de ChargeUp.
# Copia este archivo como .env (o configúralas en el panel de Render)
# y rellena los valores reales. NUNCA subas el .env al repositorio.

# --- Panel de administración ---
# Obligatoria en producción. Mínimo 12 caracteres o el servidor no arranca.
ADMIN_PASSWORD=

# --- Pago con tarjeta (Stripe) ---
STRIPE_SECRET_KEY=
# Firma del webhook checkout.session.completed (registra el pedido aunque
# el cliente no vuelva a la web tras pagar).
STRIPE_WEBHOOK_SECRET=

# --- Base de datos de pedidos (PostgreSQL) ---
# Obligatoria en producción: sin ella los pedidos se perderían al
# reiniciar. Para forzar el uso de orders.json en producción (no
# recomendado) pon ALLOW_JSON_ORDERS=1.
DATABASE_URL=
ALLOW_JSON_ORDERS=
# Endurecer el TLS de la base de datos (opcional). Con DATABASE_CA (el
# certificado del proveedor) se verifica el certificado del servidor;
# alternativamente DATABASE_SSL_STRICT=1 exige un certificado válido.
DATABASE_CA=
DATABASE_SSL_STRICT=

# --- Seguridad / CORS ---
# URL pública de la tienda. Si se define, CORS y las URLs de vuelta de
# Stripe se restringen a este origen (más el localhost de desarrollo).
CLIENT_URL=

# --- Email de confirmación ---
# Vía recomendada en producción (Render bloquea SMTP en el plan gratuito):
BREVO_API_KEY=
EMAIL_USER=
# Vía SMTP alternativa (local o hostings sin bloqueo):
EMAIL_PASS=
EMAIL_HOST=
EMAIL_PORT=
EMAIL_FROM=
# Correo del dueño que recibe un aviso con cada venta.
EMAIL_AVISOS=

# --- Avisos de venta y de error por Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Otros ---
# Puerto del servidor (por defecto 3001).
PORT=
